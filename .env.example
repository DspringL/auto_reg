# =============================================================================
# Any Auto Register - 环境变量配置示例
# =============================================================================
# 使用说明:
# 1. 复制此文件为 .env
# 2. 根据实际需求修改配置值
# 3. 不要将 .env 文件提交到 Git
# =============================================================================

# -----------------------------------------------------------------------------
# 服务器配置
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# 开发模式：0=生产模式，1=开发模式 (自动重载)
APP_RELOAD=0

# Conda 环境名称
APP_CONDA_ENV=any-auto-register

# -----------------------------------------------------------------------------
# 验证码服务配置
# -----------------------------------------------------------------------------

# YesCaptcha (可选，使用本地 Solver 时可不填)
# 获取地址：https://yescaptcha.com
YESCAPTCHA_CLIENT_KEY=

# 本地 Solver 配置 (默认自动启动，无需修改)
LOCAL_SOLVER_URL=http://127.0.0.1:8889
SOLVER_BROWSER_TYPE=camoufox

# -----------------------------------------------------------------------------
# 代理配置
# -----------------------------------------------------------------------------

# 本地出口代理（用于调用各动态代理商 API，需要境外网络，如 Clash / V2Ray 本地端口）
# 格式：http://ip:port 或 socks5://ip:port
LOCAL_OUTBOUND_PROXY=

# 静态兜底代理（所有动态代理商及数据库代理池均不可用时使用）
# 留空则注册时不使用代理
PROXY_URL=

# ── 神龙海外住宅代理 ──────────────────────────────────────────────────────
# 开启后优先于静态代理池和 PROXY_URL；需已配置 LOCAL_OUTBOUND_PROXY
# 获取地址：https://www.shenlongproxy.com
SHENLONG_ENABLED=false
# API 密钥（神龙后台 → 获取代理 → API提取 → 生成链接 → key 参数）
SHENLONG_API_KEY=
# 代理认证用户名密码（神龙后台 → 获取代理 → 用户名密码认证，留空则使用 IP 白名单模式）
SHENLONG_USERNAME=
SHENLONG_PASSWORD=
# 目标国家/地区代码，如 US、GB、JP、SG
SHENLONG_COUNTRY=US
# 代理协议：http 或 socks5
SHENLONG_PROTOCOL=http
# 单次 API 批量提取数量（缓存池大小，建议 10-50）
SHENLONG_FETCH_COUNT=10
# IP 有效期（分钟），与神龙 API ts 参数一致，建议 30
SHENLONG_IP_TTL=30

# -----------------------------------------------------------------------------
# 邮箱服务配置 (根据使用的服务填写)
# -----------------------------------------------------------------------------

# MoeMail (默认临时邮箱，自动注册)
MOEMAIL_API_KEY=

# 阿里企业邮箱 (AliMail Enterprise)
# 在邮箱管理后台 - 高级应用 - API开放平台 创建应用获取
ALIMAIL_APP_ID=
ALIMAIL_APP_SECRET=
ALIMAIL_DOMAIN=

# SkyMail / CloudMail
# 获取地址：https://cloudmail.ai
SKYMAIL_API_KEY=
SKYMAIL_DOMAIN=

# TempMail.lol (无需配置)
# 文档：https://tempmail.lol

# LuckMail (Temporary email service)
# Documentation: https://mails.luckyous.com
LUCKMAIL_API_KEY=

# GPTMail
GPTMAIL_API_KEY=

# CF Worker (自建邮箱)
# 参考：https://github.com/dreamhunter2333/cloudflare_temp_email
CFWORKER_API_URL=
CFWORKER_DOMAIN=

# -----------------------------------------------------------------------------
# 外部系统集成 (可选)
# -----------------------------------------------------------------------------

# Codex Protocol API (CPA)
CPA_API_URL=
CPA_API_KEY=

# Sub2API
SUB2API_URL=
SUB2API_KEY=

# Grok2API
GROK2API_URL=
GROK2API_KEY=

# -----------------------------------------------------------------------------
# 其他配置
# -----------------------------------------------------------------------------

# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 最大并发注册任务数
MAX_CONCURRENT_TASKS=5

# 默认注册重试次数
DEFAULT_RETRY_TIMES=3
